          "items": {"$ref": "#/$defs/metricGroup"}
        },
        "sampled_frame_count": {"type": "integer", "minimum": 0},
        "source_frame_count": {"type": "integer", "minimum": 0},
        "false_track_segments": {
          "type": "array",
          "items": {"$ref": "#/$defs/metricGroup"}
        },
        "false_track_segment_count": {"type": "integer", "minimum": 0},
        "neutral_ignored_predictions": {"$ref": "#/$defs/metricGroup"},
        "score_explanation": {"$ref": "#/$defs/metricGroup"},
        "occlusion_and_reacquisition": {"$ref": "#/$defs/metricGroup"},
        "timeline": {"$ref": "#/$defs/metricGroup"},
        "resources_and_isolation": {"$ref": "#/$defs/metricGroup"},
        "timing_compute": {"$ref": "#/$defs/metricGroup"},
        "reproducibility": {"$ref": "#/$defs/metricGroup"},
        "flags": {
          "type": "array",
          "items": {"$ref": "#/$defs/metricGroup"}
        },
        "serialized_byte_budget": {
          "type": "object",
