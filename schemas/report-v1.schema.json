        "match_count": {"type": "integer", "minimum": 0},
        "sut_stderr_compaction": {"$ref": "#/$defs/stderrCompaction"}
      }
    },
    "auditEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
