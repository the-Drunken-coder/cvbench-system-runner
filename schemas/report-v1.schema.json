        "resolved_container_image_id": {"type": ["string", "null"]},
        "executed_container_image_id": {"type": ["string", "null"]},
        "command": {"type": "string", "minLength": 1},
        "system_command": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "matching": {"$ref": "#/$defs/matching"},
        "external_clock": {"const": "time.monotonic_ns"},
        "timing_compute_contract": {"const": "cvbench.timing-compute/v1"},
        "delivery_policy": {"const": "cvbench.delivery-lossless/v1"},
        "replay_profile": {"type": "string", "minLength": 1},
        "replay_rate": {"type": "number", "exclusiveMinimum": 0},
        "leaderboard_class": {"type": ["string", "null"], "minLength": 1},
        "comparison_fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "comparison_inputs": {"$ref": "#/$defs/comparisonInputs"},
        "resource_envelope": {"$ref": "#/$defs/resourceEnvelope"},
        "run_budgets": {"$ref": "#/$defs/runBudgets"},
        "accounting_availability": {"$ref": "#/$defs/accountingAvailability"},
        "evaluation_order": {"$ref": "#/$defs/evaluationOrder"},
