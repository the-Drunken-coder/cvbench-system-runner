        "original_utf8_bytes"
      ],
      "properties": {
        "truncated": {"const": true},
        "retention": {"const": "head_and_tail"},
        "original_lines": {"type": "integer", "minimum": 0},
        "retained_lines": {"type": "integer", "minimum": 0},
        "omitted_lines": {"type": "integer", "minimum": 0},
        "original_utf8_bytes": {"type": "integer", "minimum": 0}
      }
    },
    "diagnostics": {
      "type": "object",
