            "mode": {"enum": ["configured_seed", "private_per_run_fallback"]},
            "algorithm": {"type": "string", "minLength": 1},
            "seed": {"type": ["string", "number", "null"]}
          }
        },
        "scenarios": {
          "type": "array",
          "items": {"$ref": "#/$defs/metricGroup"}
        }
      }
