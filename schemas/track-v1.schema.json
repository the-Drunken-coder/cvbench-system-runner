{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cvbench.dev/schemas/track-v1.schema.json",
  "title": "CVBench track event v1",
  "type": "object",
  "required": ["schema_version", "event", "sequence_id", "source_timestamp_ns"],
  "properties": {
    "schema_version": {"const": "cvbench.track/v1"},
    "event": {"enum": ["track_started", "track_update", "track_ended", "system_status", "system_error"]},
    "sequence_id": {"type": "string", "minLength": 1},
    "source_timestamp_ns": {"type": "integer", "minimum": 0},
    "track_id": {"type": "string", "minLength": 1},
    "state": {"enum": ["tentative", "confirmed", "coasting", "reacquired", "lost"]},
    "support": {"enum": ["observed", "predicted"]},
    "class_id": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "geometry": {
      "type": "object",
      "required": ["type", "space", "value"],
      "properties": {
        "type": {"const": "bbox_xyxy"},
        "space": {"const": "source_pixels"},
        "value": {"type": "array", "items": {"type": "number"}, "minItems": 4, "maxItems": 4}
      },
      "additionalProperties": false
    }
  },
  "allOf": [{
    "if": {"properties": {"event": {"enum": ["track_started", "track_update", "track_ended"]}}},
    "then": {"required": ["track_id", "state", "support", "class_id", "confidence", "geometry"]}
  }],
  "additionalProperties": true
}
