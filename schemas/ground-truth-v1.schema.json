{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cvbench.dev/schemas/ground-truth-v1.schema.json",
  "title": "CVBench ground truth v1",
  "type": "object",
  "required": ["target_id", "sequence_id", "source_timestamp_ns", "on_screen", "eligible_for_detection", "visibility_fraction", "occlusion", "class_id", "bbox_xyxy"],
  "properties": {
    "target_id": {"type": "string"},
    "sequence_id": {"type": "string"},
    "source_timestamp_ns": {"type": "integer", "minimum": 0},
    "on_screen": {"type": "boolean"},
    "eligible_for_detection": {"type": "boolean"},
    "visibility_fraction": {"type": "number", "minimum": 0, "maximum": 1},
    "occlusion": {"enum": ["none", "partial", "full"]},
    "class_id": {"type": "string"},
    "bbox_xyxy": {"type": "array", "items": {"type": "number"}, "minItems": 4, "maxItems": 4},
    "entry_event": {"type": "boolean"},
    "exit_event": {"type": "boolean"},
    "vision_loss_interval": {"type": "boolean"},
    "reappearance_event": {"type": "boolean"}
  },
  "additionalProperties": true
}
