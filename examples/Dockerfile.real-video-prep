FROM --platform=linux/amd64 python:3.12-slim@sha256:57cd7c3a7a273101a6485ba99423ee568157882804b1124b4dd04266317710de

WORKDIR /opt/cvbench
COPY pyproject.toml README.md LICENSE requirements-real-video.lock /opt/cvbench/
COPY src /opt/cvbench/src
COPY schemas /opt/cvbench/schemas
COPY scripts/hydrate_real_video_corpus.py scripts/prepare_real_video.py scripts/verify_real_video_corpus.py /opt/cvbench/scripts/

RUN python -m pip install --no-cache-dir -r requirements-real-video.lock \
    && python -m pip install --no-cache-dir --no-deps .

ENTRYPOINT ["python"]
